{
  "expo": {
    "name": "Alien Perimeter",
    "slug": "alien-perimeter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#05080f",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Alien Perimeter nutzt deinen Standort, um Invasionszonen in deiner Umgebung anzuzeigen und deine Einkesselungsrouten aufzuzeichnen."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#05080f",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Alien Perimeter nutzt deinen Standort, um Invasionszonen in deiner Umgebung anzuzeigen und deine Einkesselungsrouten aufzuzeichnen."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png",
      "output": "single",
      "bundler": "metro",
      "themeColor": "#0b1220",
      "backgroundColor": "#05080f"
    }
  }
}
